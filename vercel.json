{
  "routes": [
    { "handle": "filesystem" },
    
    {
      "src": "/ru/hi/(.*)",
      "dest": "/ru/$1",
      "status": 301
    },
    {
      "src": "/\\[object Object\\]/(.*)",
      "dest": "/en/$1",
      "status": 301
    },
    
    {
      "src": "/(zh|en|es|hi|ar|ru|fr|ja|pt|de|id|ko|it|zh-TW|da|el|fi|hu|ms|nl|sv)/?(about|contact|terms|privacy-policy|category/.+|tool/.+|search|tag/.+|tags|feedback|submit-tool|favorites)?",
      "dest": "/index.html"
    },
    {
      "src": "/?(about|contact|terms|privacy-policy|category/.+|tool/.+|search|tag/.+|tags|feedback|submit-tool|favorites)?",
      "dest": "/index.html"
    },
    {
      "src": "/.*",
      "status": 404,
      "dest": "/404.html"
    }
  ]
}
