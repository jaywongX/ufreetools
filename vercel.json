{
  "redirects": [
    {
      "source": "http://ufreetools.com/:path*",
      "destination": "https://www.ufreetools.com/:path*",
      "permanent": true
    },
    {
      "source": "https://ufreetools.com/:path*",
      "destination": "https://www.ufreetools.com/:path*",
      "permanent": true
    },
    {
      "source": "http://www.ufreetools.com/:path*",
      "destination": "https://www.ufreetools.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
} 