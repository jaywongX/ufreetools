{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "redirects": [
    { "source": "/:path+", "destination": "/:path+/", "permanent": true },
    
    { "source": "http://:domain/:path*", "destination": "https://:domain/:path*", "permanent": true },
    
    { "source": "https://:domain/:path*", "destination": "https://www.:domain/:path*", "permanent": true }
  ]
} 